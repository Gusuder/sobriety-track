PORT=4000
NODE_ENV=production

# Must be at least 32 characters in production.
# Generate example:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-strong-secret-min-32-chars

# Production database URL.
DATABASE_URL=postgres://postgres:postgres@db-host:5432/sobriety_track

# Shared Redis for distributed auth rate limiting.
REDIS_URL=redis://redis:6379

# Set true if API sits behind a trusted reverse proxy/load balancer.
TRUST_PROXY=true

# Comma-separated list of allowed origins, no spaces.
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=https://app.example.com