PORT=4000
NODE_ENV=production

# Must be at least 32 characters in production.
# Generate example:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-strong-secret-min-32-chars
ACCESS_TOKEN_TTL=1h

# Production database URL.
DATABASE_URL=postgres://postgres:postgres@db-host:5432/sobriety_track

# Shared Redis for distributed auth rate limiting.
REDIS_URL=redis://redis:6379
RATE_LIMIT_STRICT=true

# Google OAuth client ID (Web application).
GOOGLE_CLIENT_ID=

# Set true if API sits behind a trusted reverse proxy/load balancer.
TRUST_PROXY=false

# Must be set in production for /metrics access (`x-metrics-token` header).
METRICS_TOKEN=replace-with-strong-metrics-token-min-16-chars

# Must remain false in production.
ALLOW_DEV_RESET_TOKEN=false

# Comma-separated list of allowed origins, no spaces.
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=https://app.example.com
